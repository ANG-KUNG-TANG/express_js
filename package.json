    "test:admin":    "cross-env NODE_OPTIONS=--experimental-vm-modules node_modules/.bin/jest src/tests/application/admin",
    "test:ci":       "cross-env NODE_OPTIONS=--experimental-vm-modules node_modules/.bin/jest --ci --forceExit",
    "check":         "eslint .",
    "lint:fix":      "eslint . --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0",
