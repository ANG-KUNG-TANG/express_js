# ─── Database ─────────────────────────────────────────────────────────────────
# Dev:  MongoDB Atlas URI (development cluster)
# Prod: MongoDB Atlas URI (production cluster)
MONGO_URI=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# https://github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# SMTP_PASS: use a Gmail App Password (16 chars), NOT your account password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_SERVICE=gmail
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── News API ─────────────────────────────────────────────────────────────────
# https://newsdata.io → Dashboard → API Key
NEWSDATA_API_KEY=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Dev:  redis://redis:6379  (local Docker container)
# Prod: rediss://:<password>@<host>.upstash.io:6379  (Upstash)
USE_REDIS=true
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
